<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Sistema de gestión de flotilla vehicular con control de seguros, mantenimientos y operadores">
    <meta name="theme-color" content="#001f3f">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="CRM Insurance">
    <link rel="manifest" href="/manifest.json">
    <link rel="icon" type="image/png" sizes="32x32" href="/images/logo.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/images/logo.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/images/logo.png">
    <link rel="icon" type="image/png" sizes="512x512" href="/images/logo.png">
    <link rel="shortcut icon" href="/images/logo.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/images/logo.png">
    <link rel="apple-touch-icon" href="/images/logo.png">
    <title>Gestión de Llantas | CRM Insurance System</title>
    <!-- Versión: 2.0 - Panel de revisiones mensuales y costo por km -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #0a1628;
            --primary-light: #1a2d4a;
            --secondary: #64b5f6;
            --accent: #4da6ff;
            --light: #f8f9fa;
            --dark: #1e293b;
            --gray: #64748b;
            --border: #e2e8f0;
            --shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
            --shadow-lg: 0 10px 25px -3px rgba(0, 0, 0, 0.08);
            --radius-md: 10px;
            --radius-lg: 16px;
        }
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background-color: #f0f4f8;
            color: var(--dark);
            line-height: 1.6;
        }
        header {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--border);
            padding: 0;
            margin-bottom: 0;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .header-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .logo img {
            height: 40px;
            width: auto;
            object-fit: contain;
            display: block;
        }
        .logo-text {
            font-family: 'Montserrat', sans-serif;
            font-weight: 800;
            font-size: 1.4rem;
            color: var(--primary);
            letter-spacing: -0.03em;
        }
        .logo-text span {
            background: linear-gradient(135deg, var(--accent), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .user-menu {
            display: flex;
            align-items: center;
            gap: 20px;
        }
        .btn {
            padding: 10px 24px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
            color: white;
            border: none;
            border-radius: var(--radius-md);
            text-decoration: none;
            font-weight: 500;
            font-size: 0.9rem;
            cursor: pointer;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .btn:hover {
            transform: translateY(-1px); box-shadow: 0 4px 12px rgba(10, 22, 40, 0.2);
        }
        .btn-success {
            background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
        }
        .btn-success:hover {
            transform: translateY(-1px); box-shadow: 0 4px 12px rgba(34, 197, 94, 0.2);
        }
        .btn-danger {
            background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        }
        .btn-danger:hover {
            transform: translateY(-1px); box-shadow: 0 4px 12px rgba(239, 68, 68, 0.2);
        }
        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 30px 20px;
        }
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }
        .page-title {
            font-family: 'Montserrat', sans-serif;
            font-size: 2rem;
            font-weight: 800;
            color: var(--dark);
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 12px;
            letter-spacing: -0.03em;
        }
        .page-title i {
            color: var(--accent);
        }
        .filter-section {
            background: white;
            border-radius: 8px;
            padding: 20px;
            border: 1px solid var(--border);
            margin-bottom: 24px;
        }
        .section {
            background: white;
            border-radius: var(--radius-lg);
            padding: 28px;
            border: 1px solid var(--border);
            margin-bottom: 24px;
            box-shadow: var(--shadow);
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        thead {
            background-color: #f8fafc;
        }
        th {
            padding: 12px 16px;
            text-align: left;
            font-weight: 600;
            font-size: 0.8rem;
            color: var(--gray);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 2px solid var(--border);
        }
        td {
            padding: 16px;
            border-bottom: 1px solid var(--border);
            color: var(--dark);
            font-size: 0.95rem;
        }
        tbody tr {
            transition: background-color 0.15s;
        }
        tbody tr:hover {
            background-color: #f8f9fa;
        }
        tbody tr:last-child td {
            border-bottom: none;
        }
        .badge {
            display: inline-block;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 0.78rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .badge-success {
            background-color: #dcfce7;
            color: #166534;
        }
        .badge-warning {
            background-color: #fef3c7;
            color: #92400e;
        }
        .badge-danger {
            background-color: #fee2e2;
            color: #991b1b;
        }
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--gray);
        }
        .empty-state i {
            font-size: 3.5rem;
            color: #e2e8f0;
            margin-bottom: 16px;
        }
        .empty-state h2 {
            font-family: 'Montserrat', sans-serif;
            font-size: 1.5rem;
            color: var(--dark);
            margin-bottom: 8px;
        }
        .text-muted {
            color: var(--gray);
            font-size: 0.9rem;
        }
        .font-weight-bold {
            font-weight: 700;
        }
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(4px);
        }
        .modal-content {
            background-color: white;
            margin: 5% auto;
            padding: 0;
            border-radius: var(--radius-lg);
            width: 90%;
            max-width: 600px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
            max-height: 90vh;
            overflow-y: auto;
        }
        .modal-header {
            padding: 24px 28px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .modal-header h2 {
            font-family: 'Montserrat', sans-serif;
            font-size: 1.5rem;
            font-weight: 600;
            color: var(--dark);
            margin: 0;
        }
        .modal-close {
            background: none;
            border: none;
            font-size: 1.5rem;
            color: var(--gray);
            cursor: pointer;
            padding: 0;
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 6px;
            transition: all 0.2s;
        }
        .modal-close:hover {
            background-color: #f8f9fa;
            color: var(--dark);
        }
        .modal-body {
            padding: 28px;
        }
        .form-group {
            margin-bottom: 20px;
        }
        .form-label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: var(--dark);
            font-size: 0.9rem;
        }
        .form-control {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid var(--border);
            border-radius: 6px;
            font-size: 0.95rem;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            transition: border-color 0.2s;
        }
        .form-control:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 0 4px rgba(77, 166, 255, 0.1);
        }
        .form-actions {
            display: flex;
            gap: 12px;
            margin-top: 28px;
            padding-top: 24px;
            border-top: 1px solid var(--border);
        }
        .btn-secondary {
            background: linear-gradient(135deg, #64748b 0%, #475569 100%);
            color: white;
        }
        .btn-secondary:hover {
            transform: translateY(-1px); box-shadow: 0 4px 12px rgba(100, 116, 139, 0.2);
        }
        
        /* Responsive Styles - Mobile & Tablet */
        @media (max-width: 768px) {
            .header-container {
                flex-direction: column;
                gap: 15px;
                padding: 15px;
            }
            .logo-text {
                font-size: 1.2rem;
            }
            .user-menu {
                width: 100%;
                justify-content: space-between;
                flex-wrap: wrap;
            }
            .user-menu a, .user-menu button {
                font-size: 0.85rem;
                padding: 8px 12px;
            }
            .container {
                padding: 15px 10px;
            }
            .page-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
            }
            .page-title {
                font-size: 1.5rem;
            }
            .page-header .btn {
                width: 100%;
                justify-content: center;
            }
            .filter-section, .metrics-section, .traffic-light-section {
                padding: 15px;
            }
            .metrics-grid {
                grid-template-columns: 1fr;
                gap: 15px;
            }
            .traffic-light-grid {
                grid-template-columns: 1fr;
                gap: 15px;
            }
            table {
                display: block;
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
            }
            table thead {
                display: none;
            }
            table tbody {
                display: block;
                width: 100%;
            }
            table tr {
                display: block;
                margin-bottom: 15px;
                border: 1px solid var(--border);
                border-radius: 8px;
                padding: 15px;
                background: white;
            }
            table td {
                display: block;
                text-align: right;
                padding: 8px 0;
                border: none;
                border-bottom: 1px solid #f0f0f0;
            }
            table td:last-child {
                border-bottom: none;
            }
            table td:before {
                content: attr(data-label);
                float: left;
                font-weight: 600;
                color: var(--primary);
            }
            .modal-content {
                width: 95%;
                margin: 10% auto;
                max-height: 85vh;
            }
            .modal-header {
                padding: 15px;
            }
            .modal-header h2 {
                font-size: 1.2rem;
            }
            .modal-body {
                padding: 15px;
            }
            .form-actions {
                flex-direction: column;
            }
            .form-actions .btn {
                width: 100%;
            }
            td > div {
                display: flex;
                flex-direction: column;
                gap: 8px;
            }
            .btn-review, .btn-history {
                font-size: 0.75rem;
                padding: 6px 10px;
            }
        }
        
        @media (max-width: 480px) {
            .logo-text {
                font-size: 1rem;
            }
            .user-menu {
                flex-direction: column;
                width: 100%;
            }
            .user-menu a, .user-menu button {
                width: 100%;
                text-align: center;
            }
            .page-title {
                font-size: 1.3rem;
            }
            .container {
                padding: 10px 5px;
            }
            table td {
                font-size: 0.85rem;
            }
            .modal-content {
                width: 100%;
                margin: 0;
                border-radius: 0;
                max-height: 100vh;
            }
        }
    </style>
</head>
<body>
    <header>
        <div class="header-container">
            <div class="logo">
                <img src="/images/logo.png" alt="Logo">
                <div class="logo-text">CRM <span>Insurance</span> System</div>
            </div>
            <div class="user-menu">
                <span><%= user.nombre || user.username %></span>
                <a href="/dashboard" class="btn">Dashboard</a>
                <a href="/vehicles" class="btn">Vehículos</a>
                <a href="/policies" class="btn">Pólizas</a>
                <a href="/tires" class="btn">Llantas</a>
                <a href="/fines" class="btn">Multas</a>
                <a href="/billing" class="btn">Facturación</a>
                <a href="/logout" class="btn btn-danger">Cerrar Sesión</a>
            </div>
        </div>
    </header>

    <div class="container">
        <div class="page-header">
            <h1 class="page-title">
                <i class="fas fa-circle"></i>
                Gestión de Llantas
            </h1>
            <button class="btn btn-success" onclick="openModal()">
                <i class="fas fa-plus"></i> Agregar Llanta
            </button>
        </div>

        <div class="filter-section">
            <form method="GET" action="/tires" style="display: flex; gap: 12px; align-items: end;">
                <div style="flex: 1;">
                    <label class="form-label">Filtrar por Vehículo</label>
                    <select class="form-control" name="vehicle_id" onchange="this.form.submit()">
                        <option value="">Todos los vehículos</option>
                        <% if (vehicles && vehicles.length > 0) { %>
                            <% vehicles.forEach(function(vehicle) { %>
                            <option value="<%= vehicle.id %>" <%= String(selectedVehicle) === String(vehicle.id) ? 'selected' : '' %>>
                                #<%= vehicle.numero_vehiculo %> - <%= vehicle.marca %> <%= vehicle.modelo %>
                            </option>
                            <% }); %>
                        <% } else { %>
                            <option value="" disabled>No hay vehículos registrados</option>
                        <% } %>
                    </select>
                </div>
            </form>
            <% if (!vehicles || vehicles.length === 0) { %>
            <div style="margin-top: 15px; padding: 15px; background-color: #fff3cd; border-left: 4px solid #ffc107; border-radius: 4px;">
                <strong>⚠️ No hay vehículos registrados</strong>
                <p style="margin: 8px 0 0 0; font-size: 0.9rem; color: #856404;">
                    Para agregar llantas, primero necesitas registrar vehículos en el módulo de <a href="/vehicles" style="color: var(--primary); font-weight: 600;">Vehículos</a>.
                </p>
            </div>
            <% } %>
        </div>

        <!-- Semáforo de Llantas -->
        <% if (tires.length > 0) { %>
        <div class="section">
            <h2 style="font-family: 'Montserrat', sans-serif; font-size: 1.5rem; margin-bottom: 20px; color: var(--dark);">
                <i class="fas fa-traffic-light"></i> Semáforo de Estado de Llantas
            </h2>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 30px;">
                <div style="background: white; padding: 30px; border-radius: 12px; box-shadow: var(--shadow); text-align: center; border-top: 4px solid #28a745;">
                    <div style="font-size: 3rem; margin-bottom: 15px;">🟢</div>
                    <h3 style="color: #28a745; margin-bottom: 10px;">Óptimo</h3>
                    <p style="color: #666; font-size: 0.95rem;">Presión y profundidad dentro de los rangos recomendados</p>
                    <div style="margin-top: 15px; font-size: 1.2rem; font-weight: 600;">
                        <% 
                        const optimalCount = tires.filter(t => {
                            const presionOk = t.presion_psi && t.presion_psi >= 30 && t.presion_psi <= 35;
                            const profundidadOk = t.profundidad_mm && t.profundidad_mm >= 3;
                            return presionOk && profundidadOk && t.estado === 'Activo';
                        }).length;
                        %>
                        <%= optimalCount %> llanta(s)
                    </div>
                </div>
                <div style="background: white; padding: 30px; border-radius: 12px; box-shadow: var(--shadow); text-align: center; border-top: 4px solid #ffc107;">
                    <div style="font-size: 3rem; margin-bottom: 15px;">🟡</div>
                    <h3 style="color: #ffc107; margin-bottom: 10px;">Atención</h3>
                    <p style="color: #666; font-size: 0.95rem;">Requiere revisión o rotación próxima</p>
                    <div style="margin-top: 15px; font-size: 1.2rem; font-weight: 600;">
                        <% 
                        const warningCount = tires.filter(t => {
                            const presionWarning = t.presion_psi && (t.presion_psi < 30 || t.presion_psi > 35);
                            const profundidadWarning = t.profundidad_mm && t.profundidad_mm < 3 && t.profundidad_mm >= 1.6;
                            return (presionWarning || profundidadWarning) && t.estado === 'Activo';
                        }).length;
                        %>
                        <%= warningCount %> llanta(s)
                    </div>
                </div>
                <div style="background: white; padding: 30px; border-radius: 12px; box-shadow: var(--shadow); text-align: center; border-top: 4px solid #dc3545;">
                    <div style="font-size: 3rem; margin-bottom: 15px;">🔴</div>
                    <h3 style="color: #dc3545; margin-bottom: 10px;">Crítico</h3>
                    <p style="color: #666; font-size: 0.95rem;">Reemplazo urgente necesario</p>
                    <div style="margin-top: 15px; font-size: 1.2rem; font-weight: 600;">
                        <% 
                        const criticalCount = tires.filter(t => {
                            const profundidadCritical = t.profundidad_mm && t.profundidad_mm < 1.6;
                            return (profundidadCritical || t.estado === 'Desgastado') && t.estado !== 'Reemplazado';
                        }).length;
                        %>
                        <%= criticalCount %> llanta(s)
                    </div>
                </div>
            </div>

            <!-- Métricas Detalladas -->
            <div style="background: #f8f9fa; padding: 30px; border-radius: 12px; margin-bottom: 20px;">
                <h3 style="font-family: 'Montserrat', sans-serif; font-size: 1.3rem; margin-bottom: 25px; color: var(--primary);">
                    Métricas de Control
                </h3>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 25px;">
                    <div>
                        <h4 style="color: var(--accent); margin-bottom: 15px; display: flex; align-items: center; gap: 10px;">
                            <i class="fas fa-tachometer-alt"></i> PRESIÓN
                        </h4>
                        <p style="color: #666; line-height: 1.8; font-size: 0.9rem; margin-bottom: 10px;">Monitoreo de presión en PSI. Rango óptimo: 30-35 PSI.</p>
                        <div style="background: white; padding: 15px; border-radius: 8px;">
                            <% 
                            const tiresWithPressure = tires.filter(t => t.presion_psi);
                            const avgPressure = tiresWithPressure.length > 0 
                                ? (tiresWithPressure.reduce((sum, t) => sum + t.presion_psi, 0) / tiresWithPressure.length).toFixed(1)
                                : 0;
                            const pressureStatus = avgPressure >= 30 && avgPressure <= 35 ? 'Normal' : avgPressure < 30 ? 'Baja' : 'Alta';
                            const pressureColor = avgPressure >= 30 && avgPressure <= 35 ? '#28a745' : '#ffc107';
                            %>
                            <strong>Promedio:</strong> <span style="color: <%= pressureColor %>; font-weight: 600;"><%= avgPressure %> PSI</span><br>
                            <strong>Estado:</strong> <span style="color: <%= pressureColor %>;"><%= pressureStatus %></span>
                        </div>
                    </div>
                    <div>
                        <h4 style="color: var(--accent); margin-bottom: 15px; display: flex; align-items: center; gap: 10px;">
                            <i class="fas fa-ruler-vertical"></i> MILÍMETROS
                        </h4>
                        <p style="color: #666; line-height: 1.8; font-size: 0.9rem; margin-bottom: 10px;">Profundidad de banda. Mínimo legal: 1.6mm. Recomendado: 3mm+.</p>
                        <div style="background: white; padding: 15px; border-radius: 8px;">
                            <% 
                            const tiresWithDepth = tires.filter(t => t.profundidad_mm);
                            const avgDepth = tiresWithDepth.length > 0 
                                ? (tiresWithDepth.reduce((sum, t) => sum + t.profundidad_mm, 0) / tiresWithDepth.length).toFixed(1)
                                : 0;
                            let depthStatus = 'Sin datos';
                            let depthColor = '#6c757d';
                            if (avgDepth > 0) {
                                if (avgDepth >= 3) {
                                    depthStatus = 'Óptimo';
                                    depthColor = '#28a745';
                                } else if (avgDepth >= 1.6) {
                                    depthStatus = 'Atención';
                                    depthColor = '#ffc107';
                                } else {
                                    depthStatus = 'Crítico';
                                    depthColor = '#dc3545';
                                }
                            }
                            %>
                            <strong>Promedio:</strong> <span style="color: <%= depthColor %>; font-weight: 600;"><%= avgDepth %> mm</span><br>
                            <strong>Estado:</strong> <span style="color: <%= depthColor %>;"><%= depthStatus %></span>
                        </div>
                    </div>
                    <div>
                        <h4 style="color: var(--accent); margin-bottom: 15px; display: flex; align-items: center; gap: 10px;">
                            <i class="fas fa-sync-alt"></i> ROTACIÓN
                        </h4>
                        <p style="color: #666; line-height: 1.8; font-size: 0.9rem; margin-bottom: 10px;">Rotaciones cada 10,000-15,000 km para desgaste uniforme.</p>
                        <div style="background: white; padding: 15px; border-radius: 8px;">
                            <% 
                            const tiresNeedingRotation = tires.filter(t => {
                                if (!t.kilometraje_actual) return false;
                                if (t.kilometraje_rotacion) {
                                    const kmSinceRotation = t.kilometraje_actual - t.kilometraje_rotacion;
                                    return kmSinceRotation >= 10000;
                                } else if (t.kilometraje_instalacion) {
                                    const kmSinceInstallation = t.kilometraje_actual - t.kilometraje_instalacion;
                                    return kmSinceInstallation >= 10000;
                                }
                                return false;
                            }).length;
                            %>
                            <strong>Pendientes:</strong> <span style="color: <%= tiresNeedingRotation > 0 ? '#ffc107' : '#28a745' %>; font-weight: 600;"><%= tiresNeedingRotation %> llanta(s)</span><br>
                            <strong>Estado:</strong> <span style="color: <%= tiresNeedingRotation > 0 ? '#ffc107' : '#28a745' %>;"><%= tiresNeedingRotation > 0 ? 'Requiere rotación' : 'Al día' %></span>
                        </div>
                    </div>
                    <div>
                        <h4 style="color: var(--accent); margin-bottom: 15px; display: flex; align-items: center; gap: 10px;">
                            <i class="fas fa-dollar-sign"></i> COSTO POR KILÓMETRO
                        </h4>
                        <p style="color: #666; line-height: 1.8; font-size: 0.9rem; margin-bottom: 10px;">Cálculo basado en costo de llanta y km recorridos.</p>
                        <div style="background: white; padding: 15px; border-radius: 8px;">
                            <% 
                            const tiresWithCostAndKm = tires.filter(t => t.costo && t.kilometraje_actual && t.kilometraje_instalacion && t.kilometraje_actual > t.kilometraje_instalacion);
                            let avgCostPerKm = 0;
                            if (tiresWithCostAndKm.length > 0) {
                                let totalCost = 0;
                                let totalKm = 0;
                                tiresWithCostAndKm.forEach(t => {
                                    totalCost += (t.costo || 0);
                                    totalKm += (t.kilometraje_actual - t.kilometraje_instalacion);
                                });
                                avgCostPerKm = totalKm > 0 ? (totalCost / totalKm) : 0;
                            }
                            %>
                            <strong>Promedio:</strong> <span style="color: var(--primary); font-weight: 600;">$<%= avgCostPerKm.toFixed(4) %>/km</span><br>
                            <strong>Total:</strong> <span style="color: #666; font-size: 0.9rem;"><%= tiresWithCostAndKm.length %> registro(s)</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <% } %>

        <div class="section">
            <% if (tires.length === 0) { %>
            <div class="empty-state">
                <i class="fas fa-circle"></i>
                <h2>No hay llantas registradas</h2>
                <p>Comienza agregando el registro de llantas para tus vehículos</p>
                <button class="btn btn-success" onclick="openModal()" style="margin-top: 20px;">
                    <i class="fas fa-plus"></i> Agregar Llanta
                </button>
            </div>
            <% } else { %>
            <table>
                <thead>
                    <tr>
                        <th>Vehículo</th>
                        <th>Posición</th>
                        <th>Marca/Modelo</th>
                        <th>Presión (PSI)</th>
                        <th>Profundidad (mm)</th>
                        <th>Kilometraje Instalación</th>
                        <th>Costo</th>
                        <th>Costo/Km</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% tires.forEach(function(tire) { %>
                    <tr>
                        <td>
                            <strong>#<%= tire.numero_vehiculo %></strong><br>
                            <span class="text-muted" style="font-size: 0.85rem;"><%= tire.marca %> <%= tire.modelo %></span>
                        </td>
                        <td class="font-weight-bold"><%= tire.posicion %></td>
                        <td>
                            <%= tire.marca || '-' %> <%= tire.modelo || '' %><br>
                            <% if (tire.medida) { %>
                                <span class="text-muted" style="font-size: 0.85rem;"><%= tire.medida %></span>
                            <% } %>
                        </td>
                        <td>
                            <% if (tire.presion_psi) { %>
                                <%= tire.presion_psi %> PSI
                                <% 
                                const presionStatus = tire.presion_psi >= 30 && tire.presion_psi <= 35 ? 'success' : 
                                                      tire.presion_psi < 30 || tire.presion_psi > 35 ? 'warning' : '';
                                if (presionStatus) {
                                %>
                                    <span class="badge badge-<%= presionStatus %>" style="margin-left: 8px; font-size: 0.7rem;">
                                        <%= tire.presion_psi < 30 ? 'Baja' : 'Alta' %>
                                    </span>
                                <% } %>
                            <% } else { %>
                                <span class="text-muted">-</span>
                            <% } %>
                        </td>
                        <td>
                            <% if (tire.profundidad_mm) { %>
                                <%= tire.profundidad_mm %> mm
                                <% 
                                const profundidadStatus = tire.profundidad_mm >= 3 ? 'success' : 
                                                          tire.profundidad_mm >= 1.6 ? 'warning' : 'danger';
                                %>
                                <span class="badge badge-<%= profundidadStatus %>" style="margin-left: 8px; font-size: 0.7rem;">
                                    <%= tire.profundidad_mm >= 3 ? 'Óptimo' : tire.profundidad_mm >= 1.6 ? 'Atención' : 'Crítico' %>
                                </span>
                            <% } else { %>
                                <span class="text-muted">-</span>
                            <% } %>
                        </td>
                        <td data-label="Kilometraje Instalación">
                            <% if (tire.kilometraje_instalacion) { %>
                                <%= tire.kilometraje_instalacion.toLocaleString() %> km
                                <% if (tire.kilometraje_actual) { %>
                                    <% 
                                    let kmSinceRotation = 0;
                                    if (tire.kilometraje_rotacion) {
                                        kmSinceRotation = tire.kilometraje_actual - tire.kilometraje_rotacion;
                                    } else {
                                        kmSinceRotation = tire.kilometraje_actual - tire.kilometraje_instalacion;
                                    }
                                    if (kmSinceRotation >= 10000) {
                                    %>
                                        <span class="badge badge-warning" style="margin-left: 8px; font-size: 0.7rem;">
                                            Rotación pendiente (<%= Math.floor(kmSinceRotation / 1000) %>k km)
                                        </span>
                                    <% } %>
                                <% } %>
                            <% } else { %>
                                <span class="text-muted">-</span>
                            <% } %>
                        </td>
                        <td data-label="Costo">
                            <% if (tire.costo) { %>
                                $<%= tire.costo.toLocaleString('es-ES', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                            <% } else { %>
                                <span class="text-muted">-</span>
                            <% } %>
                        </td>
                        <td data-label="Costo/Km">
                            <% 
                            let costPerKm = 0;
                            if (tire.costo && tire.kilometraje_actual && tire.kilometraje_instalacion && tire.kilometraje_actual > tire.kilometraje_instalacion) {
                                const kmRecorridos = tire.kilometraje_actual - tire.kilometraje_instalacion;
                                costPerKm = tire.costo / kmRecorridos;
                            %>
                                <span style="font-weight: 600; color: var(--primary);">
                                    $<%= costPerKm.toFixed(4) %>/km
                                </span>
                                <br>
                                <span class="text-muted" style="font-size: 0.8rem;">
                                    <%= (tire.kilometraje_actual - tire.kilometraje_instalacion).toLocaleString() %> km
                                </span>
                            <% } else { %>
                                <span class="text-muted">-</span>
                            <% } %>
                        </td>
                        <td data-label="Estado">
                            <span class="badge badge-<%= tire.estado === 'Activo' ? 'success' : 'warning' %>">
                                <%= tire.estado %>
                            </span>
                        </td>
                        <td data-label="Acciones">
                            <div style="display: flex; gap: 6px; flex-wrap: wrap;">
                                <button class="btn btn-review" style="padding: 4px 10px; font-size: 0.8rem; background-color: #17a2b8;" data-tire-id="<%= tire.id %>" data-tire-info="<%= tire.posicion %> - <%= tire.marca || '' %> <%= tire.modelo || '' %>">
                                    <i class="fas fa-calendar-check"></i> Revisión
                                </button>
                                <button class="btn btn-history-tire" style="padding: 4px 10px; font-size: 0.8rem; background-color: #6c757d;" data-tire-id="<%= tire.id %>" data-tire-info="<%= tire.posicion %> - <%= tire.marca || '' %> <%= tire.modelo || '' %>">
                                    <i class="fas fa-history"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
            <% } %>
        </div>
    </div>

    <!-- Modal -->
    <div id="tireModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Agregar Llanta</h2>
                <button class="modal-close" onclick="closeModal()">&times;</button>
            </div>
            <div class="modal-body">
                <form id="tireForm">
                    <div class="form-group">
                        <label class="form-label">Vehículo *</label>
                        <select class="form-control" name="vehicle_id" required>
                            <option value="">Seleccionar vehículo</option>
                            <% vehicles.forEach(function(vehicle) { %>
                            <option value="<%= vehicle.id %>">#<%= vehicle.numero_vehiculo %> - <%= vehicle.marca %> <%= vehicle.modelo %></option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Posición *</label>
                        <div style="display: flex; gap: 10px; align-items: center; margin-bottom: 10px;">
                            <select class="form-control" name="posicion" id="posicionSelect" required style="flex: 1;">
                                <option value="">Seleccionar posición</option>
                                <% for (let i = 1; i <= 34; i++) { %>
                                <option value="Posición <%= i %>">Posición <%= i %></option>
                                <% } %>
                            </select>
                            <button type="button" class="btn" onclick="toggleQuickFill()" style="background-color: var(--accent); padding: 12px 20px;">
                                <i class="fas fa-check-square"></i> Llenado Rápido
                            </button>
                        </div>
                        <!-- Panel de Llenado Rápido -->
                        <div id="quickFillPanel" style="display: none; background: #f8f9fa; padding: 20px; border-radius: 8px; border: 2px solid var(--accent); margin-top: 15px;">
                            <h4 style="color: var(--primary); margin-bottom: 15px; font-size: 1.1rem;">
                                <i class="fas fa-bolt"></i> Selección Rápida de Posiciones
                            </h4>
                            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 10px; max-height: 300px; overflow-y: auto; padding: 10px;">
                                <% for (let i = 1; i <= 34; i++) { %>
                                <label style="display: flex; align-items: center; gap: 8px; padding: 8px; background: white; border-radius: 6px; cursor: pointer; border: 2px solid #dee2e6; transition: all 0.2s;" 
                                       onmouseover="this.style.borderColor='var(--accent)'; this.style.backgroundColor='#e7f3ff';" 
                                       onmouseout="this.style.borderColor='#dee2e6'; this.style.backgroundColor='white';">
                                    <input type="checkbox" class="position-checkbox" value="Posición <%= i %>" data-position="<%= i %>" 
                                           style="width: 20px; height: 20px; cursor: pointer; accent-color: var(--accent);"
                                           onchange="updatePositionFromCheckbox()">
                                    <span style="font-weight: 600; color: var(--dark);">Pos. <%= i %></span>
                                </label>
                                <% } %>
                            </div>
                            <div style="margin-top: 15px; display: flex; gap: 10px; justify-content: flex-end;">
                                <button type="button" class="btn btn-secondary" onclick="selectAllPositions()" style="padding: 8px 16px; font-size: 0.9rem;">
                                    <i class="fas fa-check-double"></i> Seleccionar Todas
                                </button>
                                <button type="button" class="btn btn-secondary" onclick="clearAllPositions()" style="padding: 8px 16px; font-size: 0.9rem;">
                                    <i class="fas fa-times"></i> Limpiar
                                </button>
                                <button type="button" class="btn" onclick="applySelectedPosition()" style="background-color: var(--accent); padding: 8px 16px; font-size: 0.9rem;">
                                    <i class="fas fa-check"></i> Aplicar
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Marca</label>
                        <input type="text" class="form-control" name="marca" placeholder="Ej: Michelin, Goodyear">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Modelo</label>
                        <input type="text" class="form-control" name="modelo" placeholder="Ej: XM2, Assurance">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Medida</label>
                        <input type="text" class="form-control" name="medida" placeholder="Ej: 205/55R16">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Número de Serie</label>
                        <input type="text" class="form-control" name="numero_serie">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Presión (PSI)</label>
                        <input type="number" step="0.1" class="form-control" name="presion_psi" placeholder="Ej: 32.0">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Profundidad de Banda (mm)</label>
                        <input type="number" step="0.1" class="form-control" name="profundidad_mm" placeholder="Ej: 8.5">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Fecha de Instalación</label>
                        <input type="date" class="form-control" name="fecha_instalacion">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Kilometraje de Instalación</label>
                        <input type="number" class="form-control" name="kilometraje_instalacion" placeholder="Ej: 50000">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Costo de Llanta Nueva</label>
                        <input type="number" step="0.01" class="form-control" name="costo" id="costoLlantaNueva" placeholder="0.00" oninput="calcularCostoPorKm()">
                    </div>
                    
                    <!-- Calculadora de Costo por Kilómetro -->
                    <div class="calculator-section" style="background: #f8f9fa; padding: 20px; border-radius: 8px; margin: 20px 0; border: 2px solid var(--accent);">
                        <h3 style="color: var(--primary); margin-bottom: 20px; font-size: 1.2rem;">
                            <i class="fas fa-calculator"></i> Calculadora de Costo por Kilómetro
                        </h3>
                        
                        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 20px;">
                            <div>
                                <h4 style="color: var(--accent); margin-bottom: 15px; font-size: 1rem;">Información sobre Llantas Nuevas</h4>
                                <div class="form-group" style="margin-bottom: 15px;">
                                    <label class="form-label" style="font-size: 0.9rem;">Valor de la Llanta Nueva</label>
                                    <div style="position: relative;">
                                        <span style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: #666;">$</span>
                                        <input type="number" step="0.01" class="form-control" id="valorLlantaNueva" placeholder="6000" style="padding-left: 25px;" oninput="calcularCostoPorKm()">
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="form-label" style="font-size: 0.9rem;">Kilómetros de Llanta Nueva</label>
                                    <input type="number" class="form-control" id="kmLlantaNueva" placeholder="300000" oninput="calcularCostoPorKm()">
                                </div>
                            </div>
                            
                            <div>
                                <h4 style="color: var(--accent); margin-bottom: 15px; font-size: 1rem;">Información de Reencauche</h4>
                                <div class="form-group" style="margin-bottom: 10px;">
                                    <label class="form-label" style="font-size: 0.9rem;">Número de Reencauches</label>
                                    <select class="form-control" id="numReencauches" onchange="toggleReencauches()" style="font-size: 0.9rem;">
                                        <option value="0">0</option>
                                        <option value="1">1</option>
                                        <option value="2">2</option>
                                        <option value="3">3</option>
                                    </select>
                                </div>
                                <div id="reencauche1" style="display: none; margin-bottom: 10px;">
                                    <div class="form-group" style="margin-bottom: 8px;">
                                        <label class="form-label" style="font-size: 0.85rem;">Reencauche 1 Valor</label>
                                        <div style="position: relative;">
                                            <span style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: #666; font-size: 0.85rem;">$</span>
                                            <input type="number" step="0.01" class="form-control" id="reencauche1Valor" placeholder="0.00" style="padding-left: 25px; font-size: 0.9rem;" oninput="calcularCostoPorKm()">
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label" style="font-size: 0.85rem;">Reencauche 1 KM</label>
                                        <input type="number" class="form-control" id="reencauche1Km" placeholder="0" style="font-size: 0.9rem;" oninput="calcularCostoPorKm()">
                                    </div>
                                </div>
                                <div id="reencauche2" style="display: none; margin-bottom: 10px;">
                                    <div class="form-group" style="margin-bottom: 8px;">
                                        <label class="form-label" style="font-size: 0.85rem;">Reencauche 2 Valor</label>
                                        <div style="position: relative;">
                                            <span style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: #666; font-size: 0.85rem;">$</span>
                                            <input type="number" step="0.01" class="form-control" id="reencauche2Valor" placeholder="0.00" style="padding-left: 25px; font-size: 0.9rem;" oninput="calcularCostoPorKm()">
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label" style="font-size: 0.85rem;">Reencauche 2 KM</label>
                                        <input type="number" class="form-control" id="reencauche2Km" placeholder="0" style="font-size: 0.9rem;" oninput="calcularCostoPorKm()">
                                    </div>
                                </div>
                                <div id="reencauche3" style="display: none;">
                                    <div class="form-group" style="margin-bottom: 8px;">
                                        <label class="form-label" style="font-size: 0.85rem;">Reencauche 3 Valor</label>
                                        <div style="position: relative;">
                                            <span style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: #666; font-size: 0.85rem;">$</span>
                                            <input type="number" step="0.01" class="form-control" id="reencauche3Valor" placeholder="0.00" style="padding-left: 25px; font-size: 0.9rem;" oninput="calcularCostoPorKm()">
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label" style="font-size: 0.85rem;">Reencauche 3 KM</label>
                                        <input type="number" class="form-control" id="reencauche3Km" placeholder="0" style="font-size: 0.9rem;" oninput="calcularCostoPorKm()">
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Resultados -->
                        <div style="background: white; padding: 20px; border-radius: 8px; border: 1px solid var(--border);">
                            <h4 style="color: var(--primary); margin-bottom: 15px; font-size: 1.1rem;">Resultados</h4>
                            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px;">
                                <div>
                                    <label style="font-size: 0.9rem; color: #666; display: block; margin-bottom: 5px;">Total de la Inversión:</label>
                                    <div style="font-size: 1.3rem; font-weight: 600; color: var(--primary);" id="totalInversion">$0.00</div>
                                </div>
                                <div>
                                    <label style="font-size: 0.9rem; color: #666; display: block; margin-bottom: 5px;">Total de KM:</label>
                                    <div style="font-size: 1.3rem; font-weight: 600; color: var(--primary);" id="totalKm">0</div>
                                </div>
                                <div>
                                    <label style="font-size: 0.9rem; color: #666; display: block; margin-bottom: 5px;">Costo por KM:</label>
                                    <div style="font-size: 1.3rem; font-weight: 600; color: var(--accent);" id="costoPorKm">$0.0000</div>
                                </div>
                            </div>
                            <div style="margin-top: 15px; padding-top: 15px; border-top: 1px solid var(--border);">
                                <label style="font-size: 0.85rem; color: #666; display: block; margin-bottom: 5px;">Fórmula de Costo por KM:</label>
                                <div style="font-size: 0.85rem; color: #666; font-style: italic;" id="formulaCostoKm">
                                    (Costo de Llanta Nueva + Reencauches) / (Kilómetros de la Llanta Nueva + Reencauches)
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">Estado</label>
                        <select class="form-control" name="estado">
                            <option value="Activo">Activo</option>
                            <option value="Reemplazado">Reemplazado</option>
                            <option value="Desgastado">Desgastado</option>
                        </select>
                    </div>
                    <div class="form-actions">
                        <button type="button" class="btn btn-secondary" onclick="closeModal()">Cancelar</button>
                        <button type="submit" class="btn btn-success">Guardar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal de Revisión Mensual -->
    <div id="reviewModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 id="reviewModalTitle">Agregar Revisión Mensual</h2>
                <button class="modal-close" onclick="closeReviewModal()">&times;</button>
            </div>
            <div class="modal-body">
                <form id="reviewForm">
                    <div class="form-group">
                        <label class="form-label">Fecha de Revisión *</label>
                        <input type="date" class="form-control" name="fecha_revision" required id="reviewFecha">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Presión (PSI)</label>
                        <input type="number" step="0.1" class="form-control" name="presion_psi" placeholder="Ej: 32.0" id="reviewPresion">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Profundidad de Banda (mm)</label>
                        <input type="number" step="0.1" class="form-control" name="profundidad_mm" placeholder="Ej: 8.5" id="reviewProfundidad">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Kilometraje</label>
                        <input type="number" class="form-control" name="kilometraje" placeholder="Ej: 55000" id="reviewKilometraje">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Observaciones</label>
                        <textarea class="form-control" name="observaciones" rows="3" placeholder="Notas adicionales sobre la revisión"></textarea>
                    </div>
                    <div class="form-actions">
                        <button type="button" class="btn btn-secondary" onclick="closeReviewModal()">Cancelar</button>
                        <button type="submit" class="btn btn-success">Guardar Revisión</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal de Historial de Revisiones -->
    <div id="reviewsHistoryModal" class="modal">
        <div class="modal-content" style="max-width: 800px;">
            <div class="modal-header">
                <h2 id="reviewsHistoryModalTitle">Historial de Revisiones</h2>
                <button class="modal-close" onclick="closeReviewsHistoryModal()">&times;</button>
            </div>
            <div class="modal-body">
                <div id="reviewsHistoryList"></div>
            </div>
        </div>
    </div>

    <script>
        function openModal() {
            document.getElementById('tireModal').style.display = 'block';
            // Sincronizar valores si ya existen en el formulario
            setTimeout(function() {
                const costoInput = document.getElementById('costoLlantaNueva');
                const kmInput = document.querySelector('input[name="kilometraje_instalacion"]');
                if (costoInput && costoInput.value) {
                    const valorInput = document.getElementById('valorLlantaNueva');
                    if (valorInput) valorInput.value = costoInput.value;
                }
                if (kmInput && kmInput.value) {
                    const kmInputCalc = document.getElementById('kmLlantaNueva');
                    if (kmInputCalc) kmInputCalc.value = kmInput.value;
                }
                calcularCostoPorKm();
            }, 100);
        }

        function closeModal() {
            document.getElementById('tireModal').style.display = 'none';
            document.getElementById('tireForm').reset();
        }

        let currentTireId = null;

        function openReviewModal(tireId, tireInfo) {
            currentTireId = tireId;
            document.getElementById('reviewModalTitle').textContent = 'Revisión Mensual - ' + tireInfo;
            document.getElementById('reviewModal').style.display = 'block';
            // Establecer fecha actual por defecto
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('reviewFecha').value = today;
        }

        function closeReviewModal() {
            document.getElementById('reviewModal').style.display = 'none';
            document.getElementById('reviewForm').reset();
            currentTireId = null;
        }

        function openReviewsHistoryModal(tireId, tireInfo) {
            currentTireId = tireId;
            document.getElementById('reviewsHistoryModalTitle').textContent = 'Historial de Revisiones - ' + tireInfo;
            document.getElementById('reviewsHistoryModal').style.display = 'block';
            loadReviewsHistory();
        }

        function closeReviewsHistoryModal() {
            document.getElementById('reviewsHistoryModal').style.display = 'none';
            currentTireId = null;
        }

        async function loadReviewsHistory() {
            if (!currentTireId) return;
            
            try {
                const response = await fetch('/api/tires/' + currentTireId + '/reviews');
                const data = await response.json();
                
                const container = document.getElementById('reviewsHistoryList');
                if (data.success && data.reviews.length > 0) {
                    container.innerHTML = data.reviews.map(function(review) {
                        return '<div class="history-item" style="padding: 15px; border-left: 3px solid var(--accent); margin-bottom: 12px; background-color: #f8f9fa; border-radius: 4px;"><div style="display: flex; justify-content: space-between; margin-bottom: 8px;"><span style="font-weight: 600; color: var(--primary);">' + new Date(review.fecha_revision).toLocaleDateString('es-ES') + '</span><span style="font-size: 0.85rem; color: var(--gray);">' + new Date(review.created_at).toLocaleString('es-ES') + '</span></div><div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 15px; margin-bottom: 8px;"><div><strong>Presión:</strong> ' + (review.presion_psi ? review.presion_psi + ' PSI' : 'N/A') + '</div><div><strong>Profundidad:</strong> ' + (review.profundidad_mm ? review.profundidad_mm + ' mm' : 'N/A') + '</div><div><strong>Kilometraje:</strong> ' + (review.kilometraje ? review.kilometraje.toLocaleString() + ' km' : 'N/A') + '</div></div>' + (review.observaciones ? '<div style="font-size: 0.9rem; color: var(--dark); margin-top: 8px; padding-top: 8px; border-top: 1px solid var(--border);"><strong>Observaciones:</strong> ' + review.observaciones + '</div>' : '') + '</div>';
                    }).join('');
                } else {
                    container.innerHTML = '<p class="text-muted">No hay revisiones registradas aún</p>';
                }
            } catch (error) {
                console.error('Error cargando historial de revisiones:', error);
                container.innerHTML = '<p class="text-muted">Error al cargar el historial</p>';
            }
        }

        document.getElementById('tireForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const formData = new FormData(this);
            const data = Object.fromEntries(formData);
            // Convert numeric fields
            if (data.presion_psi) data.presion_psi = parseFloat(data.presion_psi);
            if (data.profundidad_mm) data.profundidad_mm = parseFloat(data.profundidad_mm);
            if (data.kilometraje_instalacion) data.kilometraje_instalacion = parseInt(data.kilometraje_instalacion);
            if (data.costo) data.costo = parseFloat(data.costo);

            try {
                const response = await fetch('/api/tires', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(data)
                });

                const result = await response.json();
                if (result.success) {
                    alert('Llantas registrada exitosamente');
                    location.reload();
                } else {
                    alert('Error: ' + (result.error || 'Error desconocido'));
                }
            } catch (error) {
                alert('Error al guardar: ' + error.message);
            }
        });

        // Formulario de revisión mensual
        document.getElementById('reviewForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            if (!currentTireId) {
                alert('Error: No se ha seleccionado una llanta');
                return;
            }

            const formData = new FormData(this);
            const data = Object.fromEntries(formData);
            // Convert numeric fields
            if (data.presion_psi) data.presion_psi = parseFloat(data.presion_psi);
            if (data.profundidad_mm) data.profundidad_mm = parseFloat(data.profundidad_mm);
            if (data.kilometraje) data.kilometraje = parseInt(data.kilometraje);

            try {
                const response = await fetch('/api/tires/' + currentTireId + '/reviews', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(data)
                });

                const result = await response.json();
                if (result.success) {
                    alert('Revisión mensual guardada exitosamente');
                    closeReviewModal();
                    location.reload();
                } else {
                    alert('Error: ' + (result.error || 'Error desconocido'));
                }
            } catch (error) {
                alert('Error al guardar revisión: ' + error.message);
            }
        });

        // Event listeners para botones de revisión e historial
        // Usar evento inmediato si DOM ya está cargado, o esperar DOMContentLoaded
        function attachTireButtons() {
            // Botones de revisión mensual
            const reviewButtons = document.querySelectorAll('.btn-review');
            console.log('Botones de revisión encontrados:', reviewButtons.length);
            reviewButtons.forEach(function(btn) {
                btn.addEventListener('click', function() {
                    const tireId = parseInt(this.getAttribute('data-tire-id'));
                    const tireInfo = this.getAttribute('data-tire-info');
                    openReviewModal(tireId, tireInfo);
                });
            });

            // Botones de historial de revisiones
            const historyButtons = document.querySelectorAll('.btn-history-tire');
            console.log('Botones de historial encontrados:', historyButtons.length);
            historyButtons.forEach(function(btn) {
                btn.addEventListener('click', function() {
                    const tireId = parseInt(this.getAttribute('data-tire-id'));
                    const tireInfo = this.getAttribute('data-tire-info');
                    openReviewsHistoryModal(tireId, tireInfo);
                });
            });
        }

        // Intentar inmediatamente si el DOM ya está cargado
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', attachTireButtons);
        } else {
            attachTireButtons();
        }

        window.onclick = function(event) {
            const modal = document.getElementById('tireModal');
            if (event.target === modal) {
                closeModal();
            }
        }

        // Funciones de la calculadora de costo por kilómetro
        function toggleReencauches() {
            const numReencauches = parseInt(document.getElementById('numReencauches').value) || 0;
            document.getElementById('reencauche1').style.display = numReencauches >= 1 ? 'block' : 'none';
            document.getElementById('reencauche2').style.display = numReencauches >= 2 ? 'block' : 'none';
            document.getElementById('reencauche3').style.display = numReencauches >= 3 ? 'block' : 'none';
            calcularCostoPorKm();
        }

        function calcularCostoPorKm() {
            // Obtener valores de llanta nueva
            const valorLlantaNueva = parseFloat(document.getElementById('valorLlantaNueva').value) || 0;
            const kmLlantaNueva = parseFloat(document.getElementById('kmLlantaNueva').value) || 0;
            
            // Sincronizar con el campo de costo del formulario
            const costoInput = document.getElementById('costoLlantaNueva');
            if (costoInput && valorLlantaNueva > 0) {
                costoInput.value = valorLlantaNueva;
            }
            
            // Sincronizar con el campo de kilometraje de instalación
            const kmInput = document.querySelector('input[name="kilometraje_instalacion"]');
            if (kmInput && kmLlantaNueva > 0) {
                kmInput.value = kmLlantaNueva;
            }
            
            // Obtener valores de reencauches
            const numReencauches = parseInt(document.getElementById('numReencauches').value) || 0;
            let totalReencauches = 0;
            let totalKmReencauches = 0;
            
            if (numReencauches >= 1) {
                const rec1Valor = parseFloat(document.getElementById('reencauche1Valor').value) || 0;
                const rec1Km = parseFloat(document.getElementById('reencauche1Km').value) || 0;
                totalReencauches += rec1Valor;
                totalKmReencauches += rec1Km;
            }
            
            if (numReencauches >= 2) {
                const rec2Valor = parseFloat(document.getElementById('reencauche2Valor').value) || 0;
                const rec2Km = parseFloat(document.getElementById('reencauche2Km').value) || 0;
                totalReencauches += rec2Valor;
                totalKmReencauches += rec2Km;
            }
            
            if (numReencauches >= 3) {
                const rec3Valor = parseFloat(document.getElementById('reencauche3Valor').value) || 0;
                const rec3Km = parseFloat(document.getElementById('reencauche3Km').value) || 0;
                totalReencauches += rec3Valor;
                totalKmReencauches += rec3Km;
            }
            
            // Calcular totales
            const totalInversion = valorLlantaNueva + totalReencauches;
            const totalKm = kmLlantaNueva + totalKmReencauches;
            
            // Calcular costo por kilómetro
            let costoPorKm = 0;
            if (totalKm > 0) {
                costoPorKm = totalInversion / totalKm;
            }
            
            // Actualizar resultados
            document.getElementById('totalInversion').textContent = '$' + totalInversion.toLocaleString('es-ES', {minimumFractionDigits: 2, maximumFractionDigits: 2});
            document.getElementById('totalKm').textContent = totalKm.toLocaleString('es-ES');
            document.getElementById('costoPorKm').textContent = '$' + costoPorKm.toFixed(4);
            
            // Actualizar fórmula
            let formula = '(Costo de Llanta Nueva (' + valorLlantaNueva.toLocaleString('es-ES') + ')';
            if (totalReencauches > 0) {
                formula += ' + Reencauches ((' + totalReencauches.toLocaleString('es-ES') + ') = ' + totalInversion.toLocaleString('es-ES') + ')';
            } else {
                formula += ' = ' + totalInversion.toLocaleString('es-ES') + ')';
            }
            formula += ' / Kilómetros de la Llanta Nueva (' + kmLlantaNueva.toLocaleString('es-ES') + ')';
            if (totalKmReencauches > 0) {
                formula += ' + Reencauches ((' + totalKmReencauches.toLocaleString('es-ES') + ') = ' + totalKm.toLocaleString('es-ES') + ')';
            }
            formula += ')';
            
            document.getElementById('formulaCostoKm').textContent = formula;
        }

        // Sincronizar cuando se escriben valores directamente en los campos del formulario
        document.addEventListener('DOMContentLoaded', function() {
            const costoInput = document.getElementById('costoLlantaNueva');
            const kmInput = document.querySelector('input[name="kilometraje_instalacion"]');
            if (costoInput) {
                costoInput.addEventListener('input', function() {
                    const valorInput = document.getElementById('valorLlantaNueva');
                    if (valorInput && this.value) {
                        valorInput.value = this.value;
                        calcularCostoPorKm();
                    }
                });
            }
            if (kmInput) {
                kmInput.addEventListener('input', function() {
                    const kmInputCalc = document.getElementById('kmLlantaNueva');
                    if (kmInputCalc && this.value) {
                        kmInputCalc.value = this.value;
                        calcularCostoPorKm();
                    }
                });
            }
        });

        // Funciones para el llenado rápido de posiciones
        function toggleQuickFill() {
            const panel = document.getElementById('quickFillPanel');
            if (panel.style.display === 'none' || !panel.style.display) {
                panel.style.display = 'block';
            } else {
                panel.style.display = 'none';
            }
        }

        function updatePositionFromCheckbox() {
            const checkboxes = document.querySelectorAll('.position-checkbox:checked');
            if (checkboxes.length === 1) {
                // Si solo hay una seleccionada, actualizar el select
                document.getElementById('posicionSelect').value = checkboxes[0].value;
            }
        }

        function selectAllPositions() {
            const checkboxes = document.querySelectorAll('.position-checkbox');
            checkboxes.forEach(cb => cb.checked = true);
        }

        function clearAllPositions() {
            const checkboxes = document.querySelectorAll('.position-checkbox');
            checkboxes.forEach(cb => cb.checked = false);
            document.getElementById('posicionSelect').value = '';
        }

        function applySelectedPosition() {
            const checkboxes = document.querySelectorAll('.position-checkbox:checked');
            if (checkboxes.length === 0) {
                alert('Por favor selecciona al menos una posición');
                return;
            }
            if (checkboxes.length === 1) {
                // Si solo hay una, aplicar directamente
                document.getElementById('posicionSelect').value = checkboxes[0].value;
                document.getElementById('quickFillPanel').style.display = 'none';
            } else {
                // Si hay múltiples, usar la primera
                document.getElementById('posicionSelect').value = checkboxes[0].value;
                alert('Se aplicó la primera posición seleccionada. Para múltiples llantas, agrega una por una.');
                document.getElementById('quickFillPanel').style.display = 'none';
            }
        }
    </script>
</body>
</html>

