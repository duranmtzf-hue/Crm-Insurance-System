            }
            .fcrm-content .chart-container {
                position: relative;
                min-height: 240px;
                margin-left: -4px;
                margin-right: -4px;
            }
        }
        .fcrm-kpi {
            background: #fff;
            border: 1px solid var(--fcrm-border);
            border-radius: 14px;
            padding: 16px 18px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 1px 3px rgba(15, 23, 42, 0.06);
        }
        .fcrm-kpi::before {
            content: '';
