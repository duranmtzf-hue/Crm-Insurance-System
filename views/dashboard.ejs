                padding: max(16px, env(safe-area-inset-top, 0px)) 16px max(16px, env(safe-area-inset-bottom, 0px)) max(16px, env(safe-area-inset-left, 0px));
                margin: 0;
                z-index: 3000;
                transform: translateX(-105%);
                transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                box-shadow: none;
                overflow-y: auto;
                -webkit-overflow-scrolling: touch;
                /* Cerrado: no interceptar toques (evita que el drawer tapa el botón hamburguesa / topbar) */
                pointer-events: none;
            }
            .fcrm-app.fcrm-nav-open .fcrm-side {
