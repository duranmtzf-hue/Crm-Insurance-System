                background: rgba(15, 23, 42, 0.42);
                backdrop-filter: blur(4px);
                -webkit-backdrop-filter: blur(4px);
                opacity: 0;
                visibility: hidden;
                pointer-events: none;
                transition: opacity 0.25s ease, visibility 0.25s ease;
            }
            /* Backdrop es hermano de #fcrmApp (fuera del flex) para evitar bugs de layout/toques */
            .fcrm-app.fcrm-nav-open ~ .fcrm-nav-backdrop {
                opacity: 1;
                visibility: visible;
                pointer-events: auto;
            }
            .fcrm-kpi-row {
                grid-template-columns: 1fr;
