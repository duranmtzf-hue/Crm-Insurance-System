                font-size: 0.78rem;
            }
            .fcrm-topbar-actions {
                gap: 8px;
                flex-wrap: wrap;
                justify-content: flex-end;
            }
            .fcrm-topbar-actions .user-info {
                display: none;
            }
            .fcrm-topbar .connection-status span:last-child {
