        .fcrm-nav-toggle i {
            font-size: 1.15rem;
        }
        .fcrm-nav-backdrop {
            display: none;
        }
        body.fcrm-no-scroll {
            overflow: hidden;
            touch-action: none;
        }
        @media (max-width: 1200px) {
            .fcrm-kpi-row {
                grid-template-columns: repeat(3, minmax(0, 1fr));
