</head>
<body class="fcrm-body">
<% 
  var fcrmDisplayName = (user && user.nombre) ? String(user.nombre) : (user && user.username) ? String(user.username) : 'Usuario';
  var fcrmParts = fcrmDisplayName.trim().split(/\s+/);
  var fcrmA = (fcrmParts[0] && fcrmParts[0].charAt(0)) ? fcrmParts[0].charAt(0) : 'U';
  var fcrmB = (fcrmParts[1] && fcrmParts[1].charAt(0)) ? fcrmParts[1].charAt(0) : (fcrmParts[0] && fcrmParts[0].length > 1 ? fcrmParts[0].charAt(1) : '');
  var fcrmInitials = (fcrmA + fcrmB).toUpperCase().substring(0, 2);
%>
<div class="fcrm-app" id="fcrmApp">
    <aside class="fcrm-side" id="fcrmSide">
        <div class="fcrm-side-brand">
            <img src="/images/logo.png" alt="">
            <div>
                <div class="fcrm-side-brand-txt">CRM <span>Insurance</span></div>
            </div>
        </div>
        <nav class="fcrm-side-nav" aria-label="Módulos">
            <a href="/dashboard" class="fcrm-side-item active"><i class="fas fa-chart-line"></i> Dashboard</a>
            <a href="/vehicles" class="fcrm-side-item"><i class="fas fa-car"></i> Vehículos <% if (stats && stats.totalVehicles) { %><span class="fcrm-side-badge"><%= stats.totalVehicles %></span><% } %></a>
            <a href="/tracking" class="fcrm-side-item"><i class="fas fa-map-location-dot"></i> Rastreo GPS</a>
            <a href="/billing" class="fcrm-side-item"><i class="fas fa-file-invoice"></i> Facturación</a>
            <a href="/fines" class="fcrm-side-item"><i class="fas fa-gavel"></i> Multas</a>
            <a href="/expenses" class="fcrm-side-item"><i class="fas fa-coins"></i> Gastos</a>
            <a href="/reports" class="fcrm-side-item"><i class="fas fa-file-lines"></i> Reportes</a>
            <a href="/policies" class="fcrm-side-item"><i class="fas fa-shield-halved"></i> Pólizas</a>
            <a href="/claims" class="fcrm-side-item"><i class="fas fa-car-burst"></i> Siniestros</a>
            <a href="/tires" class="fcrm-side-item"><i class="fas fa-circle-dot"></i> Llantas</a>
        </nav>
        <div class="fcrm-side-footer">
            <div class="fcrm-ava"><%= fcrmInitials %></div>
            <div class="fcrm-ava-meta">
                <div class="fcrm-ava-name"><%= fcrmDisplayName %></div>
                <div class="fcrm-ava-role">Sesión activa</div>
            </div>
            <a href="/logout" class="fcrm-side-logout" title="Cerrar sesión"><i class="fas fa-sign-out-alt"></i></a>
        </div>
    </aside>
    <div class="fcrm-main">
        <header class="fcrm-topbar">
            <button type="button" class="fcrm-nav-toggle" id="fcrmNavToggle" aria-label="Abrir menú" aria-expanded="false" aria-controls="fcrmSide" onclick="window.fcrmToggleNav(event)">
                <i class="fas fa-bars" aria-hidden="true"></i>
            </button>
            <div class="fcrm-breadcrumb">
                <a href="/dashboard">Inicio</a>
                <span>/</span>
                <strong>Dashboard</strong>
            </div>
            <div class="fcrm-tb-spacer"></div>
            <form class="fcrm-tb-search" action="/vehicles" method="get" role="search">
                <i class="fas fa-search" aria-hidden="true"></i>
                <input type="search" name="q" placeholder="Buscar placa, marca, # vehículo..." aria-label="Buscar vehículos" title="Busca en tu lista de vehículos">
            </form>
            <a href="/api/download-report" class="fcrm-tb-btn fcrm-tb-btn-outline" title="Descargar reporte en PDF">
                <i class="fas fa-file-pdf"></i> Exportar
            </a>
            <a href="/vehicles" class="fcrm-tb-btn fcrm-tb-btn-primary">
                <i class="fas fa-plus"></i> Nuevo vehículo
            </a>
