            </div>
            <div class="fcrm-kpi" style="--kpi-accent:#2563eb">
                <span class="fcrm-kpi-lab">Pólizas por Vencer</span>
                <span class="fcrm-kpi-val"><%= stats.expiringPolicies %></span>
