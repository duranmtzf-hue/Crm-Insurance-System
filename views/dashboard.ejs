                <span class="fcrm-kpi-delta positive"><i class="fas fa-arrow-up"></i> <%= stats.totalVehicles > 0 ? Math.round((stats.activeVehicles / stats.totalVehicles) * 100) : 0 %>% disponibilidad</span>
            </div>
            <div class="fcrm-kpi" style="--kpi-accent:#60a5fa">
