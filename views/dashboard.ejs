            }
            .fcrm-topbar .connection-status {
                padding: 8px 10px;
                min-width: 44px;
                justify-content: center;
            }
            .fcrm-tb-search {
                order: 8;
                flex: 1 1 100%;
                max-width: none;
                min-height: 46px;
                padding: 10px 14px;
                border-radius: 12px;
            }
            .fcrm-tb-search input {
                font-size: 16px;
            }
            .fcrm-tb-btn {
                min-height: 44px;
                padding: 10px 14px;
                font-size: 0.78rem;
                border-radius: 12px;
                touch-action: manipulation;
            }
            .fcrm-content {
                padding: max(12px, env(safe-area-inset-left, 0px)) max(12px, env(safe-area-inset-right, 0px)) max(28px, env(safe-area-inset-bottom, 0px));
                padding-top: 14px;
            }
            .fcrm-pg-head {
                flex-direction: column;
                align-items: stretch;
                gap: 10px;
                margin-bottom: 16px;
            }
            .fcrm-pg-head h1 {
                font-size: 1.4rem;
            }
            .fcrm-pg-meta {
                text-align: left;
                font-size: 0.72rem;
            }
            .fcrm-kpi {
                padding: 14px 16px;
            }
            .fcrm-kpi-val {
                font-size: 1.6rem;
            }
            .fcrm-content .section {
                padding: 18px 14px;
